# OTOMANET Environment Variables

# Security
SECRET_KEY=generate_a_random_secret_key_here
ENCRYPTION_KEY=generate_a_fernet_key_using_cryptography_library

# Database
# SQLite: sqlite:///./otomanet.db
# PostgreSQL: postgresql://user:password@localhost/otomanet
DATABASE_URL=sqlite:///./otomanet.db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0

# Application
DEBUG=True
LOG_LEVEL=INFO
BACKUP_DIR=./backup
